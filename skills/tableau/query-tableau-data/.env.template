# Tableau environment
TABLEAU_SERVER_URL=""
TABLEAU_SITE_NAME=""

# Personal Access Token (PAT) for authentication (recommended)
PAT_NAME=""
PAT_VALUE=""

# Username/password authentication (alternative)
TABLEAU_USERNAME=""
TABLEAU_PASSWORD=""

# API versions
# TABLEAU_API_VERSION — REST API version string interpolated into endpoint URLs
# (e.g., /api/3.24/sites/...). Pin to match your Tableau Server/Cloud release.
TABLEAU_API_VERSION="3.24"

# TABLEAU_VDS_VERSION — VizQL Data Service API version path segment.
# Currently "v1" is the only available version.
TABLEAU_VDS_VERSION="v1"

# Transport options
# TABLEAU_USE_HTTP — Allow plain HTTP instead of HTTPS (true/false).
# Default is "false" (HTTPS enforced). Only set to "true" for local dev servers
# without TLS. A warning is logged when HTTP is active.
TABLEAU_USE_HTTP="false"

# TABLEAU_TIMEOUT — HTTP request timeout in seconds for all SDK API calls.
# Increase for large queries or high-latency networks.
TABLEAU_TIMEOUT="30.0"
